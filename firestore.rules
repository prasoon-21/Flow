rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user belongs to tenant
    function userBelongsToTenant(tenantId) {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId;
    }

    // Tenants collection - read-only for authenticated users of that tenant
    match /tenants/{tenantId} {
      allow read: if isAuthenticated() && userBelongsToTenant(tenantId);
      allow write: if false; // Server-only writes via service account
    }

    // Users collection - users can read their own data
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || 
                                           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow write: if false; // Server-only writes via service account
    }

    // Pages collection - read based on tenant
    match /pages/{pageId} {
      allow read: if isAuthenticated() && (
        resource.data.tenantId == null || // Shared pages
        userBelongsToTenant(resource.data.tenantId)
      );
      allow write: if false; // Server-only writes via service account
    }

    // Channels collection - read based on tenant
    match /channels/{channelId} {
      allow read: if isAuthenticated() && userBelongsToTenant(resource.data.tenantId);
      allow write: if false; // Server-only writes via service account
    }

    // Conversations collection - read based on tenant
    match /conversations/{conversationId} {
      allow read: if isAuthenticated() && userBelongsToTenant(resource.data.tenantId);
      allow write: if false; // Server-only writes via service account
    }

    // Tickets collection - read based on tenant
    match /tickets/{ticketId} {
      allow read: if isAuthenticated() && userBelongsToTenant(resource.data.tenantId);
      allow write: if false; // Server-only writes via service account
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

