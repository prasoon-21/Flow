{
  "name": "aurika-flow",
  "version": "1.0.0",
  "description": "Business operations MVP with in-memory data",
  "private": true,
  "scripts": {
    "dev:local": "next dev",
    "dev:test": "APP_ENV=test next dev",
    "start": "next start",
    "start:prod": "APP_ENV=prod next start",
    "build": "next build",
    "build:test": "APP_ENV=test next build",
    "build:prod": "APP_ENV=prod next build",
    "db:migrate-indexes": "tsx scripts/migrate-indexes.ts",
    "db:deploy-indexes:staging": "firebase deploy --only firestore:indexes --project staging",
    "db:deploy-indexes:prod": "firebase deploy --only firestore:indexes --project prod",
    "db:seed": "tsx scripts/seed.ts",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.943.0",
    "@aws-sdk/s3-request-presigner": "^3.943.0",
    "@tanstack/react-query": "^4.36.1",
    "@trpc/client": "^10.45.0",
    "@trpc/next": "^10.45.0",
    "@trpc/react-query": "^10.45.0",
    "@trpc/server": "^10.45.0",
    "bcryptjs": "^2.4.3",
    "firebase": "^10.12.2",
    "firebase-admin": "^12.0.0",
    "googleapis": "^165.0.0",
    "lucide-react": "^0.552.0",
    "next": "^14.2.35",
    "pdf-lib": "^1.17.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sanitize-html": "^2.17.0",
    "swagger-ui-react": "^5.17.14",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/sanitize-html": "^2.16.0",
    "dotenv": "^17.2.3",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.1.0",
    "firebase-tools": "^15.3.1",
    "prettier": "^3.2.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
